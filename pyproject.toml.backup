[tool.poetry]
name = "mmk-panel"
version = "0.1.0"
description = "The official Django backend for the MMK online game."
authors = ["v81d <v81d@proton.me>"]
readme = "README.md"
license = "GPL-3.0-or-later"
packages = [
  { include = "mmk_panel" }
]

[tool.poetry.dependencies]
python = "^3.12"
django = "^6.0.4"
python-dotenv = "^1.2.2"
psycopg2-binary = "^2.9.12"
django-storages = "^1.14.6"
boto3 = "^1.42.96"
django-unfold = "^0.90.0"
ruff = "^0.15.12"
pillow = "<12.2"

[build-system]
requires = ["poetry-core"]
build-backend = "poetry.core.masonry.api"
